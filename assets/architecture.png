from src.langgraphagenticai.state.state import State</p><p class="whitespace-pre-wrap break-words">class BasicChatbotNode:
    """
    Basic Chatbot login implementation
    """
    def __init__(self,model):
        self.llm=model</p><p class="whitespace-pre-wrap break-words">    def process(self,state:State)-&gt;dict:
        """
        Processes the input state and generates a chatbot response.
        """
        return {"messages":self.llm.invoke(state['messages'])}</p><p class="whitespace-pre-wrap break-words">  from src.langgraphagenticai.state.state import State</p><p class="whitespace-pre-wrap break-words">class ChatbotWithToolNode:
    """
    Chatbot logic enhanced with tool integration.
    """
    def __init__(self,model):
        self.llm = model</p><p class="whitespace-pre-wrap break-words">    def process(self, state: State) -&gt; dict:
        """
        Processes the input state and generates a response with tool integration.
        """
        user_input = state["messages"][-1] if state["messages"] else ""
        llm_response = self.llm.invoke([{"role": "user", "content": user_input}])</p><p class="whitespace-pre-wrap break-words">        # Simulate tool-specific logic
        tools_response = f"Tool integration for: '{user_input}'"</p><p class="whitespace-pre-wrap break-words">        return {"messages": [llm_response, tools_response]}</p><p class="whitespace-pre-wrap break-words">    def create_chatbot(self, tools):
        """
        Returns a chatbot node function.
        """
        llm_with_tools = self.llm.bind_tools(tools)</p><p class="whitespace-pre-wrap break-words">        def chatbot_node(state: State):
            """
            Chatbot logic for processing the input state and returning a response.
            """
            return {"messages": [llm_with_tools.invoke(state["messages"])]}</p><p class="whitespace-pre-wrap break-words">        return chatbot_node</p><p class="whitespace-pre-wrap break-words">  this is how they look
