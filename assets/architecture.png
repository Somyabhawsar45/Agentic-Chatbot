persist</span><span class="token token" style="color: rgb(211, 215, 222);">(</span><span class="token token" style="color: rgb(155, 233, 99);">"user"</span><span class="token token" style="color: rgb(211, 215, 222);">,</span><span> self</span><span class="token token" style="color: rgb(211, 215, 222);">.</span><span>user_message</span><span class="token token" style="color: rgb(211, 215, 222);">)</span><span>  </span><span class="token token" style="color: rgb(129, 136, 152);"># appends to chat_history</span><span>
